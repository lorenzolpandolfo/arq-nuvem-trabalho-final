# Copie este arquivo para terraform.tfvars e preencha os valores
# NUNCA commite terraform.tfvars no Git (já está no .gitignore)

aws_region    = "us-east-1"
project       = "arq-nuvem"
environment   = "prod"
instance_type = "t3.micro"
key_pair_name = "arq-nuvem-key"

# Senhas — use valores fortes em produção
db_password       = "TROQUE_POR_SENHA_FORTE_123!"
rabbitmq_password = "TROQUE_POR_SENHA_FORTE_456!"
